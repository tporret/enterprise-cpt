{
  "name": "enterprise-cpt/enterprise-cpt",
  "description": "JSON-first CPT and field engine for enterprise WordPress projects.",
  "type": "wordpress-plugin",
  "require": {
    "php": "^8.3"
  },
  "config": {
    "platform": {
      "php": "8.3"
    }
  },
  "autoload": {
    "psr-4": {
      "EnterpriseCPT\\": "src/"
    }
  },
  "scripts": {
    "verify-php": "find . -name '*.php' | xargs php -l",
    "schema:verify": "php tests/SchemaTableNameTest.php"
  }
}